# --- Web app ---
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# --- Security ---
# Random URL-safe string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace_me

# Fernet key used to encrypt Discord/email passwords and tokens.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_me

# --- MongoDB (local) ---
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=discord

# --- Discord ---
# User-Agent used for all Discord HTTP requests
DISCORD_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
DISCORD_API_BASE=https://discord.com/api/v9
# Per-request timeout (seconds)
DISCORD_HTTP_TIMEOUT=20

# --- AI providers (used by identity-generator) ---
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Monitoring ---
MONITOR_ENABLED=true
MONITOR_TOPIC_INTERVAL=60
MONITOR_DM_INTERVAL=300

# --- IMAP (used to read Discord verification emails) ---
# Built-in domain map covers Rambler properties (rambler.ru, myrambler.ru,
# autorambler.ru, lenta.ru, ro.ru, rambler.com, rambler.org).
# Set IMAP_DEFAULT_HOST as the fallback for any other domain.
IMAP_DEFAULT_HOST=
IMAP_DEFAULT_PORT=993
IMAP_FETCH_LIMIT=10
IMAP_TIMEOUT=25

# --- Discord gateway (used for activity / voice join) ---
DISCORD_GATEWAY_URL=wss://gateway.discord.gg/?v=9&encoding=json
GATEWAY_IDENTIFY_OS=Windows
GATEWAY_IDENTIFY_BROWSER=Chrome
